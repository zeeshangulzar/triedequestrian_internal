<style>
  @media (max-width: 768px) {
  .wrapper--full2 {
    display: block !important;
  }
  .wrapper--full2 ul {
    display: flex;
    margin: 10px 0 0 0;
    padding: 0;
    flex-wrap: wrap;
    border: 1px solid;
  }
  .wrapper--full2 ul li {
    flex: 0 0 50%;
    border: 1px solid;
    margin: 0;
  }
  .wrapper--full2 ul li a {
    display: flex;
    padding: 10px 25px;
    text-align: center;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 15px;
    align-items: center;
    justify-content: center;
  }
  .wrapper--full2 ul li a span {
    max-width: 100px;
  }
}
</style>
<!-- /sections/section-html.liquid -->
<div class="section-html wrapper--full2"
  style="display:none;--PT: {{ section.settings.padding_top }}px; --PB: {{ section.settings.padding_bottom }}px;">
  <div class=" {{ section.settings.width }} section-padding">
        <ul>
      {% for link in section.settings.link.links %}
       <li>
         <a href="{{ link.url }}"><span>{{ link.title }}</span></a>
       </li>
      {% endfor %}
      </ul>
  </div>
</div>

{% schema %}
{
  "name": "Custom Menu (Mobile)",
  "settings": [
    {
      "type": "link_list",
      "id": "link",
      "label": "Menu", 
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--none", "label": "Full width" },
        { "value": "wrapper--full", "label": "Full width padded" },
        { "value": "wrapper", "label": "Page width" },
        { "value": "wrapper--narrow", "label": "Page width narrow" },
        { "value": "wrapper--tiny", "label": "Page width extra narrow" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "category": "Text",
      "name": "Custom Menu  (Mobile)"
    }
  ],
  "disabled_on": {
    "groups": ["header","footer","aside"]
  }
}
{% endschema %}
