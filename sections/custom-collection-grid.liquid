  <script>
    // Defensive: if jQuery isn't available at execution time, don't throw and
    // accidentally prevent the rest of the dropdown handlers from attaching.
    if (window.jQuery) {
      jQuery(document).on("mouseover", ".filter-bar .filter-group", function () {
        if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
          return;
        }

        var $this = jQuery(this);
        var position = $this.offset().left - jQuery(".filter-bar").offset().left;
        $this.find(".filter-dropdown").css({ left: -position, "min-width": jQuery(".filter-bar").width() + "px" });
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      const body = document.body;
      const filterShell = document.querySelector(".fsbdjsdf");

      function disableBodyScroll() {
        const scrollY = window.scrollY;
        body.dataset.scrollY = String(scrollY);
        body.style.position = "fixed";
        body.style.top = `-${scrollY}px`;
        body.classList.add("dropdown-open");
      }

      function enableBodyScroll() {
        const scrollY = body.dataset.scrollY || "0";
        body.style.position = "";
        body.style.top = "";
        body.classList.remove("dropdown-open");
        window.scrollTo(0, parseInt(scrollY, 10) || 0);
      }

      function closeAllGroups() {
        document.querySelectorAll(".filter-group.active").forEach(function (g) {
          g.classList.remove("active");
        });
        enableBodyScroll();
      }

      function onFilterBarClick(e) {
        if (!e.target.closest(".filter-bar")) return;

        var doneBtn = e.target.closest(".filter-done-btn");
        var closeBtn = e.target.closest(".filter-close-btn");
        var overlay = e.target.closest(".filter-overlay");
        if (doneBtn || closeBtn || overlay) {
          closeAllGroups();
          return;
        }

        var toggle = e.target.closest(".filter-toggle");
        if (toggle) {
          var group = toggle.closest(".filter-group");
          if (!group) return;
          var isActive = group.classList.contains("active");
          closeAllGroups();
          if (!isActive) {
            group.classList.add("active");
            disableBodyScroll();
          }
          e.stopPropagation();
        }
      }

      if (filterShell) {
        filterShell.addEventListener("click", onFilterBarClick, false);
      }

      document.addEventListener("click", function (e) {
        if (e.target.closest(".filter-group")) return;
        closeAllGroups();
      });
    });
  </script>



