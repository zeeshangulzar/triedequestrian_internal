  // Safari vs Chrome iterate `Object.keys(product.dataset)` in different orders; without sorting,
  // the same collection can show "Kids" before "Women's" on iOS and the opposite on Android.
  function sortOptionFilterKeys(keys) {
    function priority(k) {
      var lower = String(k).toLowerCase();
      if (lower.indexOf('women') !== -1) return 10;
      if (lower.indexOf('kid') !== -1) return 20;
      if (lower.indexOf('horse') !== -1) return 30;
      if (lower.indexOf('shoe') !== -1) return 40;
      if (lower.indexOf('color') !== -1 || lower.indexOf('colour') !== -1) return 85;
      if (lower.indexOf('size') !== -1) return 50;
      return 70;
    }
    return keys.slice().sort(function (a, b) {
      var pa = priority(a);
      var pb = priority(b);
      if (pa !== pb) return pa - pb;
      return String(a).localeCompare(String(b));
    });
  }

  // Build filters
  function buildDynamicFilters() {
    const products = Array.from(document.querySelectorAll('.product-card'));
    const filterBar = document.getElementById(`FilterBar-${sectionId}`);
    
    if (!filterBar || products.length === 0) return;
    
   const priceRanges = [
      {label: 'Under $25', value: 'under25', min: 0, max: 2500},
      {label: '$25 - $50', value: '25-50', min: 2500, max: 5000},
      {label: '$50 - $100', value: '50-100', min: 5000, max: 10000},
      {label: '$100 - $150', value: '100-150', min: 10000, max: 15000},
      {label: '$150 - $200', value: '150-200', min: 15000, max: 20000},
      {label: '$200 - $300', value: '200-300', min: 20000, max: 30000},
      {label: '$300 - $500', value: '300-500', min: 30000, max: 50000},
      {label: '$500 - $1,000', value: '500-1000', min: 50000, max: 100000},
      {label: '$1,000 - $2,500', value: '1000-2500', min: 100000, max: 250000}, 
      {label: 'Over $2,500', value: 'over2500', min: 250000, max: Infinity}
    ];
    
    const filterData = {
      vendor: new Set(),
      product_type: new Set(),
      price_range: priceRanges
    };
    
    const optionFilters = {};
    
    products.forEach(product => {
      const vendor = product.dataset.vendor;
      if (vendor) filterData.vendor.add(vendor);
      
      const productType = product.dataset.productType;
      if (productType) filterData.product_type.add(productType);
      
      Object.keys(product.dataset)
        .sort()
        .forEach(key => {
        if (['productId', 'vendor', 'price', 'productType', 'tags', 'compareAtPrice'].includes(key)) return;
        
        if (!optionFilters[key]) {
          optionFilters[key] = new Set();
        }
        
        const values = product.dataset[key]?.split(',') || [];
        values.forEach(val => {
          if (val) optionFilters[key].add(val);
        });
      });
    });
    
    let filterHTML = '';

    const optionKeys = sortOptionFilterKeys(
      Object.keys(optionFilters).filter(function (k) { return optionFilters[k].size > 0; })
    );
    function isColorOptionKey(k) {
      var lower = String(k).toLowerCase();
      return lower.indexOf('color') !== -1 || lower.indexOf('colour') !== -1;
    }
    var nonColorKeys = optionKeys.filter(function (k) { return !isColorOptionKey(k); });
    var colorKeysOnly = optionKeys.filter(isColorOptionKey);

    function appendOptionGroup(key) {
      var displayName = key.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
      filterHTML += createFilterGroup(key, displayName, Array.from(optionFilters[key]));
    }

    nonColorKeys.forEach(appendOptionGroup);

    if (filterData.vendor.size > 0) {
      filterHTML += createFilterGroup('vendor', 'Brand', Array.from(filterData.vendor));
    }

    colorKeysOnly.forEach(appendOptionGroup);

    filterHTML += createFilterGroup('price', 'Price', null, filterData.price_range);
    
    filterHTML += '<div class="filter-reset" id="ClearAllFilters">Clear All</div>';
    filterBar.innerHTML = filterHTML;
    // Create color swatches for color options
    document.querySelectorAll('.filter-group').forEach(group => {
      var fg = group.dataset && group.dataset.filterGroup;
      if (fg && (fg.indexOf('color') !== -1 || fg.indexOf('colour') !== -1)) {
        createColorSwatches(group);
      }
    });
    
    restoreActiveFilters();
    initFilterEvents();
    initSearchFunctionality();
    updatePriceDisplays();
  }
  
  function createColorSwatches(filterGroup) {
    const colorOptions = filterGroup.querySelectorAll('.filter-option');
    
    colorOptions.forEach(option => {
      const value = option.dataset.value;
      const input = option.querySelector('input');
      const textSpan = option.querySelector('span');
      const colorName = textSpan.textContent;
      
      // Create container for swatch and name
      const swatchContainer = document.createElement('div');
      swatchContainer.className = 'color-option-container';
      
      // Create color swatch
      const swatch = document.createElement('span');
      swatch.className = 'color-swatch';
      const colorValue = getColorValue(value);
      
      // Check if the colorValue is an image URL or color code
      if (colorValue.startsWith('http')) {
        // Image URL
        swatch.style.backgroundImage = `url(${colorValue})`;
        swatch.style.backgroundSize = 'cover';
        swatch.style.backgroundPosition = 'center';
      } else if (colorValue.startsWith('linear-gradient') || colorValue.startsWith('conic-gradient') || colorValue.startsWith('repeating-linear-gradient')) {
        // Gradient
        swatch.style.backgroundImage = colorValue;
      } else {
        // Plain color
        swatch.style.backgroundColor = colorValue;
      }
  
      swatch.title = colorName;
      
      // Add checkmark
      const checkmark = document.createElement('span');
      checkmark.className = 'color-checkmark';
      checkmark.innerHTML = '✓';
      swatch.appendChild(checkmark);
      
      // Create color name element
      const nameElement = document.createElement('span');
      nameElement.className = 'color-name';
      nameElement.textContent = colorName;
      
      // Build the structure
      swatchContainer.appendChild(swatch);
      swatchContainer.appendChild(nameElement);
      
      // Replace the original content
      option.innerHTML = '';
      option.appendChild(input); // Keep the hidden input
      option.appendChild(swatchContainer);
      
      // Update selected state
      if (input && input.checked) {
        option.classList.add('selected');
      }
    });
  }

  
  function getColorValue(colorName) {
    const colorMap = {
      'red': '#ff0000', 'blue': '#0000ff', 'green': '#008000',
      'yellow': '#ffff00', 'black': '#000000', 'white': '#ffffff',
      'pink': '#ffc0cb', 'purple': '#800080', 'orange': '#ffa500',
      'gray': '#808080', 'grey': '#808080', 'brown': '#8f5d46',
      'gold': '#ffd700', 'silver': '#c0c0c0', 'navy': '#000080',
      'maroon': '#800000', 'teal': '#008080', 'olive': '#808000','bronze':'#CD7F32',"beige":'#EAD8AB',
      'tan':'#DED1C2','burgundy':'#8F2424','floral':'https://cdn.shopify.com/s/files/1/1735/6525/files/download_1.jpg',
      'striped':'repeating-linear-gradient(45deg, #000, #000 5px, #fff 5px, #fff 10px)','animal':'linear-gradient(to right, #f6aa1c, #d65108, #000000)',
      'geometric':'linear-gradient(to right, #2ebf91, #8360c3, #fcb045)','multi':'conic-gradient( from 0deg, red, orange, yellow, green, blue, indigo, violet, red )',
      'blue-multi':'linear-gradient( 45deg, #0000FF, #0033FF, #3366FF, #66B2FF,  #99CCFF, #CCE5FF )','navy-multi':'linear-gradient( 45deg, #000080, #000066, #00004d, #000099, #001f4d, #003366 )',
      'blue-grey':'linear-gradient( 45deg, #607D8B, #546E7A, #455A64, #37474F, #263238 )','blue-navy':'linear-gradient(45deg,#001f3f,#003366,#004080,#00264d,#001a33)',
      'plaid':'https://cdn.shopify.com/s/files/1/1735/6525/files/Plaid.png?v=1748249874'
    };
    
    const lowerColor = colorName.toLowerCase();
    return colorMap[lowerColor] || '#f5f5f5';
  }
  
  function createFilterGroup(key, displayName, values, priceRanges = null) {
    const groupClass = `filter-group filter-group-${key.replace(/_/g, '-')}`;
    let options = '';
  
    if (key === 'price' && priceRanges) {
      priceRanges.forEach(range => {
        options += `
          <div class="filter-option" data-value="${range.value}">
            <input type="checkbox" value="${range.value}" data-filter="price" data-min="${range.min}" data-max="${range.max}">
            <span>${range.label}</span>
          </div>
        `;
      });
    } else if (values) {
      const sizeOrder = ['XXS', 'XS', 'S', 'M', 'L', 'XL', 'XXL', 'XXXL'];
  
      function normalizeSize(val) {
        if (!val) return null;
        const cleaned = val.toLowerCase().trim().replace(/\s+/g, '').replace(/[^a-z]/g, '');
  
        if (['xxs', 'xxsmall', 'xxextrasmall', 'xxextra'].includes(cleaned)) return 'XXS';
        if (['xs', 'xsmall', 'extrasmall', 'extra'].includes(cleaned)) return 'XS';
        if (['s', 'small'].includes(cleaned)) return 'S';
        if (['m', 'medium', 'med'].includes(cleaned)) return 'M';
        if (['l', 'large'].includes(cleaned)) return 'L';
        if (['xl', 'xlarge', 'extralarge'].includes(cleaned)) return 'XL';
        if (['xxl', 'xxlarge', 'xxextralarge'].includes(cleaned)) return 'XXL';
        if (['xxxl', 'xxxlarge', 'xxxextralarge'].includes(cleaned)) return 'XXXL';
  
        return null; // unknown size
      }
  
      // Map original values with normalized size and numeric value (if any)
      const mapped = values.map(v => {
        const norm = normalizeSize(v);
        const numVal = parseFloat(v);
        const isNum = !isNaN(numVal);
        return {
          original: v,
          norm,
          isNum,
          numVal: isNum ? numVal : null
        };
      });
  
      // Sort logic: known sizes first by sizeOrder, then numeric ascending, then alphabetically
      mapped.sort((a, b) => {
        // Both normalized sizes
        if (a.norm && b.norm) {
          return sizeOrder.indexOf(a.norm) - sizeOrder.indexOf(b.norm);
        }
  
        // One normalized size, one not => normalized size first
        if (a.norm && !b.norm) return -1;
        if (!a.norm && b.norm) return 1;
  
        // Both numeric
        if (a.isNum && b.isNum) {
          return a.numVal - b.numVal;
        }
  
        // One numeric, one not => text first
        if (a.isNum && !b.isNum) return 1;
        if (!a.isNum && b.isNum) return -1;
  
        // Neither normalized size nor numeric - alphabetic
        return a.original.localeCompare(b.original);
      });
  
      // Now create options with original values, but display formatted nicely
      mapped.forEach(({ original }) => {
        let formattedValue = "";
        if(original.length > 4){
          formattedValue = original.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())
        }else{
          formattedValue = original.replace(/-/g, '.').replace(/\b\w/g, l => l.toUpperCase())
        }
        options += `
          <div class="filter-option" data-value="${original}">
            <input type="checkbox" value="${original}" data-filter="${key}">
            <span>${formattedValue}</span>
          </div>
        `;
      });
    }
  
    return `
      <div class="${groupClass}" data-filter-group="${key}">
        <div class="filter-toggle">
          <span>${displayName} <b>-</b> 
            <img class="dfdccs" src="https://cdn.shopify.com/s/files/1/0919/6270/4202/files/chevron-down-svgrepo-com.svg?v=1747044780">
          </span>
          <span class="filter-count">
            <img class="dfdccs" src="https://cdn.shopify.com/s/files/1/0919/6270/4202/files/chevron-down-svgrepo-com.svg?v=1747044780">
          </span>
        </div>
  
        <div class="filter-dropdown auto-open">
          <div class="filter-search-container">
            <img class="dkfjdsbj" src="https://cdn.shopify.com/s/files/1/1735/6525/files/search-alt-1-svgrepo-com.svg?v=1747471698"> 
            <input type="text" class="filter-search-input" placeholder="Search ${displayName}..." />
            <div class="active-filters" id="ActiveFilters"></div>
            <div class="selected-options-container" style="display: none;"></div>
          </div>
          <div class="sdeasd">
            <img class="filter-close-btn" src="https://cdn.shopify.com/s/files/1/1735/6525/files/cross-circle-svgrepo-com.svg?v=1747637957">
          </div>
          <h6 style="margin-bottom:15px;font-size: 15px;">${displayName}</h6>
          <div class="filter-dropdown-inner">
            ${options}
          </div>
  
          <div class="filter-dropdown-footer">
            <button class="filter-done-btn">DONE</button>
            <button class="filter-clear-btn">CLEAR</button>
          </div>
        </div>
  
        <div class="filter-overlay"></div>
      </div>`;
  }
  
  function restoreActiveFilters() {
    for (const group in activeFilters) {
      activeFilters[group].forEach(value => {
        const checkbox = document.querySelector(`.filter-option input[value="${value}"][data-filter="${group}"]`);
        if (checkbox) {
          checkbox.checked = true;
          checkbox.closest('.filter-option').classList.add('selected');
        }
      });
    }
    
    updateActiveFiltersDisplay();
    updateFilterCounts();
    filterProducts();
  }


