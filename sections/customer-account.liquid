
<!-- /sections/customer-account.liquid -->

<div class="{{ section.settings.width }} section-padding"
  style="--PT: {{ section.settings.padding_top }}px; --PB: {{ section.settings.padding_bottom }}px;">

  {% paginate customer.orders by 50 %}
    <header class="account-header pb-4">
      <!-- Top row: My Account (left) + Logout (right) -->
      <div class="flex justify-between items-center">
        <h1 class="account-header__left body-size-6 strong">
          {{ 'customer.account.title' | t }}
        </h1>
        <a href="{{ routes.account_logout_url }}" class="text-btn-arrow-right" id="shopify-logout-link">
          {{ 'layout.customer.log_out' | t }}
        </a>
      </div>

      <!-- Below My Account: Consigner Portal Button -->
      <div id="consignor-portal-container" 
          class="mt-3" 
          data-email="{{ customer.email }}" 
          data-consignor-id="{{ customer.metafields.custom.consignor_id }}">
        <button id="switch-app-button" class="btn bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">
          Consigner Portal
        </button>
      </div>
    </header>


    <hr class="hr--small">

    <div class="float-grid mt-8">

      <div class="grid__item two-thirds medium-down--one-whole">

        <p class="kicker-flourished text-left my-5">{{ 'customer.orders.title' | t }}</p>

        {% if customer.orders.size != 0 %}
          <div class="table-wrap">
            <table class="table-full-width table--responsive">
              <thead>
                <tr>
                  <th>{{ 'customer.orders.order_number' | t }}</th>
                  <th>{{ 'customer.orders.date' | t }}</th>
                  <th>{{ 'customer.orders.payment_status' | t }}</th>
                  <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
                  <th>{{ 'customer.orders.total' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {% for order in customer.orders %}
                  <tr>
                    <td data-label="{{ 'customer.orders.order_number' | t }}"><strong class="text-link">{{ order.name | link_to: order.customer_url }}</strong></td>
                    <td data-label="{{ 'customer.orders.date' | t }}">{{ order.created_at | date: format: 'month_day_year' }}</td>
                    <td data-label="{{ 'customer.orders.payment_status' | t }}">{{ order.financial_status_label }}</td>
                    <td data-label="{{ 'customer.orders.fulfillment_status' | t }}">{{ order.fulfillment_status_label }}</td>
                    <td data-label="{{ 'customer.orders.total' | t }}">
                      {% if settings.currency_code_enable %}
                        {{ order.total_price | money_with_currency }}
                      {% else %}
                        {{ order.total_price | money }}
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <p>{{ 'customer.orders.none' | t }}</p>
        {% endif %}
      </div>

      <div class="grid__item one-third medium-down--one-whole">
        <p class="kicker-flourished text-left my-5">{{ 'customer.account.details' | t }}</p>

        <p>
        <strong>{{ customer.name }}</strong><br>
        {% if customer.default_address != nil %}
          {{ customer.default_address.address1 }}<br>
          {% if customer.default_address.address2 != "" %}
            {{ customer.default_address.address2 }}<br>
          {% endif %}
          {% if customer.default_address.city != "" %}
            {{ customer.default_address.city }}<br>
          {% endif %}
          {% if customer.default_address.province_code != "" %}
            {{ customer.default_address.province_code | upcase }}<br>
          {% endif %}
          {% if customer.default_address.zip != "" %}
            {{ customer.default_address.zip | upcase }}<br>
          {% endif %}
          {% if customer.default_address.country != "" %}
            {{ customer.default_address.country }}<br>
          {% endif %}
          {% if customer.default_address.phone != "" %}
            {{ customer.default_address.phone }}
          {% endif %}
        {% endif %}
        </p>

        <p><a class="text-btn-arrow-right mt-4" href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})</a></p>
      </div>

    </div>

    {% if paginate.pages > 1 %}
      <div class="text-center mt-7">
        {% render 'pagination-custom', paginate: paginate %}
      </div>
    {% endif %}
  {% endpaginate %}

</div>

{% javascript %}
    document.addEventListener('DOMContentLoaded', async function () {
      const THIRD_PARTY_SECRET = 'Kx9mP2vQ8nR5tY7uI3oP6aS1dF4gH7jK0lZ9';
      const portalUrl = 'https://tried-eq.herokuapp.com';
      const container = document.getElementById('consignor-portal-container');
      const switchButton = document.getElementById('switch-app-button');

      if (!container || !switchButton) {
        console.log('❌ Missing container or button');
        return;
      }

      const email = container.dataset.email;
      const consignorId = container.dataset.consignorId || '';

      console.log('🔍 Debug:', { email, consignorId });

      if (!email) {
        console.log('❌ Email missing — aborting portal script');
        return;
      }

      // Local cache
      const CACHE_KEY = 'consignor_session';
      const CACHE_EXPIRY_KEY = 'consignor_session_expiry';
      const CACHE_DURATION = 30 * 60 * 1000;

      function getCachedSession() {
        try {
          const cached = localStorage.getItem(CACHE_KEY);
          const expiry = localStorage.getItem(CACHE_EXPIRY_KEY);
          if (!cached || !expiry) return null;
          if (Date.now() < parseInt(expiry)) {
            return JSON.parse(cached);
          } else {
            clearCachedSession();
          }
        } catch {
          clearCachedSession();
        }
        return null;
      }

      function setCachedSession(data) {
        try {
          localStorage.setItem(CACHE_KEY, JSON.stringify(data));
          localStorage.setItem(CACHE_EXPIRY_KEY, (Date.now() + CACHE_DURATION).toString());
        } catch (e) {
          console.warn('⚠️ Failed to cache session', e);
        }
      }

      function clearCachedSession() {
        localStorage.removeItem(CACHE_KEY);
        localStorage.removeItem(CACHE_EXPIRY_KEY);
      }

      function enableButton() {
        console.log('🚀 Enabling portal button...');
        switchButton.style.display = 'inline-block';
        switchButton.style.opacity = '1';
        switchButton.style.pointerEvents = 'auto';
        switchButton.disabled = false;

        // Replace event listeners to avoid stacking
        const newButton = switchButton.cloneNode(true);
        switchButton.parentNode.replaceChild(newButton, switchButton);

        newButton.addEventListener('click', () => {
          console.log('🌐 Redirecting to portal...');
          window.location.href = `${portalUrl}/auth/portal-redirect?email=${encodeURIComponent(email)}&consignor_id=${encodeURIComponent(consignorId)}`;
        });
      }

      // 🧠 1️⃣ Check cache but validate with server first
      const cached = getCachedSession();
      if (cached && cached.session_active) {
        console.log('📦 Cached session found, verifying with server...');
        const verify = await fetch(`${portalUrl}/auth/session-status`, {
          method: 'GET',
          credentials: 'include',
          headers: { 'Accept': 'application/json' }
        });

        if (verify.ok) {
          const data = await verify.json();
          if (data.session_active) {
            console.log('✅ Verified cached session with server');
            setCachedSession(data);
            enableButton();
            return;
          } else {
            console.warn('⚠️ Server says no active session — clearing cache');
            clearCachedSession();
          }
        } else {
          console.warn('⚠️ Failed to verify cached session with server');
          clearCachedSession();
        }
      }

      // 🌐 2️⃣ Check session on server (no cache)
      try {
        const sessionCheck = await fetch(`${portalUrl}/auth/session-status`, {
          method: 'GET',
          credentials: 'include',
          headers: { 'Accept': 'application/json' }
        });

        if (sessionCheck.ok) {
          const sessionData = await sessionCheck.json();
          if (sessionData.session_active) {
            console.log('✅ Active server session found');
            setCachedSession(sessionData);
            enableButton();
            return;
          } else {
            console.log('ℹ️ No active server session');
            clearCachedSession();
          }
        }
      } catch (err) {
        console.error('❌ Error checking session', err);
      }

      // 📝 3️⃣ Attempt session creation if needed
      try {
        const loginUrl = `${portalUrl}/auth/third-party-login?email=${encodeURIComponent(email)}&consignor_id=${encodeURIComponent(consignorId)}&token=${THIRD_PARTY_SECRET}`;
        const loginResponse = await fetch(loginUrl, {
          method: 'GET',
          credentials: 'include',
          headers: { 'Accept': 'application/json' }
        });

        if (loginResponse.ok) {
          const loginData = await loginResponse.json();
          if (loginData.session_active) {
            console.log('✅ Session created successfully');
            setCachedSession(loginData);
            enableButton();
          } else {
            console.log('❌ Session creation failed — likely user not found');
          }
        } else {
          console.error('❌ Login request failed:', loginResponse.status);
        }
      } catch (err) {
        console.error('❌ Error creating session', err);
      }
    });
{% endjavascript %}





<script>
  document.addEventListener('DOMContentLoaded', function () {
    console.log('📄 DOM loaded, initializing portal + Shopify logout bridge...');

    // 🔸 Global error catchers to stop on ANY unexpected error
    window.addEventListener('error', function (e) {
      console.error('🚨 Global error caught:', e.error || e.message);
      debugger;
    });

    window.addEventListener('unhandledrejection', function (e) {
      console.error('🚨 Unhandled promise rejection:', e.reason);
      debugger;
    });

    // Where your portal logs out and (optionally) redirects back
    const PORTAL_LOGOUT = 'https://tried-eq.herokuapp.com/auth/third-party-logout';

    // Customer data injected server-side into the DOM by Liquid
    const container = document.getElementById('consignor-portal-container');
    const EMAIL = container ? container.dataset.email : '';
    const CONSIGNOR_ID = container ? container.dataset.consignorId : '';

    // All selectors that might match Shopify's logout link
    const LOGOUT_SELECTORS = [
      '#shopify-logout-link',
      'a[href*="/account/logout"]',
      'a[href*="account_logout_url"]',
      'a[href*="logout"]',
      '.text-btn-arrow-right' // your theme uses this on the logout link
    ];

    function findLogoutLink() {
      for (const sel of LOGOUT_SELECTORS) {
        const el = document.querySelector(sel);
        if (el && /logout/i.test(el.textContent + ' ' + el.href)) return el;
      }
      return null;
    }

    function rewriteLogoutHref(link) {
      // Build portal logout URL with return_to back to Shopify's logout
      const shopifyLogoutUrl = link.href || (location.origin + '/account/logout');
      const url = new URL(PORTAL_LOGOUT);

      if (EMAIL) url.searchParams.set('email', EMAIL);
      if (CONSIGNOR_ID) url.searchParams.set('consignor_id', CONSIGNOR_ID);

      url.searchParams.set('return_to', shopifyLogoutUrl);

      // Don't prevent default; just let the browser navigate to portal first
      link.setAttribute('href', url.toString());
      
      console.log('🔄 Rewritten logout link:', url.toString());
    }

    function attachLogoutHandler(link) {
      if (!link || link.dataset.listenerAttached) return;
      link.dataset.listenerAttached = 'true';

      console.log('🔍 Found logout link:', link.textContent);
      
      // Rewrite immediately and also ensure it stays rewritten if the theme mutates it
      rewriteLogoutHref(link);

      // Defensive: rewrite again right before navigation in case theme reassigns href
      link.addEventListener('click', () => {
        console.log('🚪 Shopify logout clicked — navigating to portal first...');
        rewriteLogoutHref(link);
      }, { capture: true });
    }

    // Attach immediately or observe
    const logoutLink = findLogoutLink();
    if (logoutLink) {
      attachLogoutHandler(logoutLink);
    } else {
      console.log('⏳ Logout link not found, observing for dynamic content...');
      
      // If the link is injected later, observe and rewrite when it appears
      const obs = new MutationObserver(() => {
        const l = findLogoutLink();
        if (l) { 
          console.log('🔍 Found logout link via observer:', l.textContent);
          attachLogoutHandler(l); 
          obs.disconnect(); 
        }
      });
      obs.observe(document.body, { childList: true, subtree: true });
      setTimeout(() => obs.disconnect(), 10000);
    }
  });
</script>



<style>
  #switch-app-button {
    display: none;
  }

  #switch-app-button.active {
    display: inline-block;
    opacity: 1;
    cursor: pointer;
    pointer-events: auto;
  }
</style>

{% schema %}
{
  "settings": [
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full", "label": "Full width padded" },
        { "value": "wrapper", "label": "Page width" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
