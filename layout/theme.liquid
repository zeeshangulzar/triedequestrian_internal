      <script>
        $("body").on("click", ".badge_btn", function(){
           $(this).toggleClass("_active");
        });

        (function () {
          var mq = window.matchMedia("(max-width: 767px)");
          var prevVisible = false;
          function snizeFiltersDialogVisible(el) {
            if (!el || el.getAttribute("aria-hidden") === "true") return false;
            var cs = window.getComputedStyle(el);
            if (cs.display === "none" || cs.visibility === "hidden" || parseFloat(cs.opacity) === 0)
              return false;
            var r = el.getBoundingClientRect();
            return r.width > 8 && r.height > 8;
          }
          function collapseSnizeFacetAccordions(root) {
            if (!root) return;
            root.querySelectorAll(".snize-product-filter-container").forEach(function (c) {
              c.classList.remove("open");
              c.style.display = "none";
            });
            root.querySelectorAll(".snize-product-filters-header:not(#snize_filters_block_header)").forEach(function (h) {
              h.classList.remove("_active");
            });
          }
          function tick() {
            if (!mq.matches) {
              prevVisible = false;
              return;
            }
            var d = document.getElementById("snize-modal-mobile-filters-dialog");
            if (!d) {
              prevVisible = false;
              return;
            }
            var visible = snizeFiltersDialogVisible(d);
            if (visible && !prevVisible) {
              collapseSnizeFacetAccordions(d);
              window.requestAnimationFrame(function () {
                collapseSnizeFacetAccordions(d);
              });
              window.setTimeout(function () {
                collapseSnizeFacetAccordions(d);
              }, 280);
            }
            prevVisible = visible;
          }
          setInterval(tick, 150);
        })();

        let dataFilters = `{{ data_filter }}`;
        let badgeCollection = `{{ html_badge }}`;
        let filterInterval = setInterval(function(){
          console.log("snize-search-results-main-content",$(".snize-search-results-main-content").length)
          if ($("#snize-search-results-grid-mode").length > 0 || $("#snize-search-results-list-mode").length > 0) {
            $("#snize_results").prepend("<div id='side-filters1'>"+dataFilters+"</div>");
            $(".snize-horizontal-left").append(badgeCollection);
            $('.snize-main-panel').append(badgeCollection);
            clearInterval(filterInterval);
           }          
        },500);

        function checkforBadge(){
          let filterInterval = setInterval(function(){
              if ($("#snize-search-results-grid-mode").length > 0 || $("#snize-search-results-list-mode").length > 0) {
                 if ($(".badge_btn").length == 0) {
                     $('.snize-main-panel').append(badgeCollection);
                 }
              }
              if($(".badge_btn").length > 0){
               clearInterval(filterInterval);
              }
          },500);
        }
      (function () {
        function applyTagBadges() {
          $('.snize-attribute').each(function () {
            const text = $(this).text().trim().toLowerCase();            
            if (text.includes('new with tags')) {
              $(this).addClass('new-with-tags tag_badge');
            }
            if (text.includes('added today') || text.includes('_badge_added_today')) {
              $(this).addClass('added-today-snize tag_badge');
            }
             if (text.includes('hot')) {
              $(this).addClass('hot__items tag_badge');
            }      
            if (text.includes('winter')) {
              $(this).addClass('season-winter tag_badge');
            }
            if (text.includes('25')) {
              $(this).addClass('badge-25 tag_badge');
            }
            if (text.includes('30')) {
              $(this).addClass('badge-30 tag_badge');
            }
            if (text.includes('40')) {
              $(this).addClass('badge-40 tag_badge');
            }
            if (text.includes('50')) {
              $(this).addClass('badge-50 tag_badge');
            }
            if (text.includes('70')) {
              $(this).addClass('badge-70 tag_badge');
            }
          });
        }

        var snizeRibbonFlagsCache = {};
        var snizeRibbonFlagsInflight = {};

        function snizeTagsMeanAddedToday(tags) {
          if (!tags || !tags.length) return false;
          for (var i = 0; i < tags.length; i++) {
            var t = String(tags[i]).trim().toLowerCase();
            if (t === 'added today' || t === '_badge_added_today') return true;
          }
          return false;
        }

        function snizeTagsMeanNewWithTags(tags) {
          if (!tags || !tags.length) return false;
          for (var i = 0; i < tags.length; i++) {
            var t = String(tags[i]).trim().toLowerCase();
            if (t === 'new with tags') return true;
          }
          return false;
        }

        function snizeParseProductHandle($li) {
          var href = $li.find('a[href*="/products/"]').first().attr('href');
          if (!href) return null;
          try {
            var u = new URL(href, window.location.origin);
            var parts = u.pathname.split('/').filter(Boolean);
            var ix = parts.indexOf('products');
            if (ix >= 0 && parts[ix + 1]) return decodeURIComponent(parts[ix + 1]);
          } catch (e) {}
          return null;
        }

        function snizeRibbonStackHtml(flags) {
          var icon =
            '<svg class="product__badge-icon" width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">' +
            '<circle cx="6.5" cy="6.5" r="5.75" stroke="currentColor" stroke-width="1.2"/>' +
            '<path d="M6.5 3.5V6.5L8.5 7.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>' +
            '</svg>';
          var chunks = [];
          if (flags.addedToday) {
            chunks.push(
              '<div class="product__badge product__badge--ribbon product__badge--added-today">' +
                icon +
                '<span>Added Today</span></div>'
            );
          }
          if (flags.newWithTags) {
            chunks.push(
              '<div class="product__badge product__badge--ribbon product__badge--new-with-tags">' +
                icon +
                '<span>NEW WITH TAGS</span></div>'
            );
          }
          if (!chunks.length) return '';
          return (
            '<div class="product-grid-item__ribbon-badges snize-ribbon-stack-anchor">' +
            chunks.join('') +
            '</div>'
          );
        }

        function snizeInjectRibbonStack($li, flags) {
          var $thumb = $li.find('span.snize-thumbnail').first();
          if (!$thumb.length || $thumb.find('.snize-ribbon-stack-anchor').length) return;
          var html = snizeRibbonStackHtml(flags);
          if (!html) return;
          $thumb.prepend(html);
          snizeSuppressFacetsForThumbnail($thumb);
        }

        function snizeSuppressFacetsForThumbnail($thumb) {
          if (!$thumb.length || !$thumb.find('.snize-ribbon-stack-anchor').length) return;
          $thumb.find('.snize-attribute').each(function () {
            var $a = $(this);
            if ($a.closest('.snize-ribbon-stack-anchor').length) return;
            var t = $a.text().trim().toLowerCase().replace(/\s+/g, ' ');
            if (!t.length) return;
            if (
              t.indexOf('new with tags') !== -1 ||
              t.indexOf('added today') !== -1 ||
              t.indexOf('_badge_added_today') !== -1
            ) {
              $a.addClass('snize-ribbon-facet-suppressed');
            }
          });
        }

        function snizeSuppressFacetsUnderAllInjectedStacks() {
          $('#snize_results span.snize-thumbnail').each(function () {
            snizeSuppressFacetsForThumbnail($(this));
          });
        }

        function snizeFetchRibbonFlagsForHandle(handle) {
          if (Object.prototype.hasOwnProperty.call(snizeRibbonFlagsCache, handle)) {
            return Promise.resolve(snizeRibbonFlagsCache[handle]);
          }
          if (snizeRibbonFlagsInflight[handle]) return snizeRibbonFlagsInflight[handle];
          var base = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
          var p = fetch(base + 'products/' + encodeURIComponent(handle) + '.js')
            .then(function (r) {
              return r.ok ? r.json() : Promise.reject(new Error('product'));
            })
            .then(function (product) {
              var raw = product.tags;
              var tags = raw;
              if (typeof raw === 'string') {
                tags = raw.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
              }
              var flags = {
                addedToday: snizeTagsMeanAddedToday(tags),
                newWithTags: snizeTagsMeanNewWithTags(tags),
              };
              snizeRibbonFlagsCache[handle] = flags;
              delete snizeRibbonFlagsInflight[handle];
              return flags;
            })
            .catch(function () {
              var empty = { addedToday: false, newWithTags: false };
              snizeRibbonFlagsCache[handle] = empty;
              delete snizeRibbonFlagsInflight[handle];
              return empty;
            });
          snizeRibbonFlagsInflight[handle] = p;
          return p;
        }

        function applySnizeRibbonStacks() {
          $('li.snize-product').each(function () {
            var $li = $(this);
            if ($li.attr('data-snize-ribbon-applied') === '1') return;
            var handle = snizeParseProductHandle($li);
            if (!handle) {
              $li.attr('data-snize-ribbon-applied', '1');
              return;
            }
            $li.attr('data-snize-ribbon-applied', '1');
            snizeFetchRibbonFlagsForHandle(handle).then(function (flags) {
              if (!flags.addedToday && !flags.newWithTags) return;
              $('li.snize-product').each(function () {
                var $x = $(this);
                if (snizeParseProductHandle($x) === handle) snizeInjectRibbonStack($x, flags);
              });
            });
          });
        }

        function onSnizeResultsMutated() {
          applyTagBadges();
          applySnizeRibbonStacks();
          snizeSuppressFacetsUnderAllInjectedStacks();
        }

        $(document).ready(function () {
          onSnizeResultsMutated();
          $(document).on('Searchanise.ResultsUpdated', function () {
            setTimeout(onSnizeResultsMutated, 50);
          });
          document.addEventListener('Searchanise.Loaded', function () {
            setTimeout(onSnizeResultsMutated, 150);
          });
          const observer = new MutationObserver(function () {
            onSnizeResultsMutated();
          });
          const target = document.querySelector('.snize-search-results') || document.body;      
          observer.observe(target, {
            childList: true,
            subtree: true
          });
        });
      })();
      </script>
       <script>
          setInterval(() => {
            const done_button = document.querySelector('.snize-product-filters-show-products');
            const show_products = document.querySelector('.snize-product-filters-showed-products');
            if (done_button && show_products) {
              done_button.textContent = show_products.textContent;
            }
          }, 500);

        </script>
    {% endif %}

