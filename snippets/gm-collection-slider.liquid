<style>
    .collection-slider-content--gm {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        position: relative;
        transition: all 0.3s ease;
        flex-shrink: 0;
        margin-top: 5px;
        width: 140px;
    }

    @media only screen and (min-width: 768px) {
        .collection-slider-content--gm {
            width: 160px;
        }
    }

    .collection-slider-content--gm a {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        padding-left: inherit;
        width: 100%;
    }

    .collection-image-wrapper {
        position: relative;
        width: 6rem;
        height: 6rem;
        border-radius: 50%;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px -4px rgba(30, 41, 59, 0.1);
        border: 2px solid #ffffff;
        outline: 0px solid transparent;
        outline-offset: 2px;
        flex-shrink: 0;
    }

    @media only screen and (min-width: 768px) {
        .collection-image-wrapper {
            width: 7rem;
            height: 7rem;
        }
    }

    .collection-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
        border-radius: 50%;
    }

    .collection-image-wrapper::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(30, 41, 59, 0);
        transition: background 0.3s ease;
        pointer-events: none;
        z-index: 2;
        border-radius: 50%;
    }

    .collection-slider-content--gm:hover .collection-image-wrapper {
        box-shadow: 0 8px 30px -8px rgba(30, 41, 59, 0.15);
    }

    .collection-slider-content--gm:hover .collection-image-wrapper::after {
        background: rgba(30, 41, 59, 0.1);
    }

    .collection-slider-content--gm:hover .collection-image-wrapper img {
        transform: scale(1.1);
    }

    .collection-slider-content--gm.active .collection-image-wrapper {
        box-shadow: 0 8px 30px -8px rgba(30, 41, 59, 0.15);
        outline: 3px solid #1e293b;
        outline-offset: 1px;
    }

    .collection-slider-content--gm.active .collection-image-wrapper::after {
        background: rgba(30, 41, 59, 0);
    }

    .collection-slider-content--gm.active .collection-image-wrapper img {
        transform: scale(1.1);
    }

    .collection-name {
        position: relative;
        padding: 0.5rem 1rem;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 9999px;
        box-shadow: 0 2px 12px -2px rgba(30, 41, 59, 0.08);
        transition: all 0.3s ease;
        font-size: 0.75rem;
        font-weight: 500;
        color: #1e1e1e;
        text-transform: capitalize;
        text-align: center;
        word-wrap: break-word;
        overflow-wrap: break-word;
        hyphens: auto;
        width: 100%;
        max-width: 140px;
        min-height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1.3;
    }

    @media only screen and (min-width: 768px) {
        .collection-name {
            font-size: 0.875rem;
            max-width: 160px;
            min-height: 40px;
        }
    }

    .collection-slider-content--gm:hover .collection-name {
        border-color: rgba(30, 41, 59, 0.3);
        box-shadow: 0 4px 20px -4px rgba(30, 41, 59, 0.1);
    }

    .collection-slider-content--gm.active .collection-name {
        background: #1e293b;
        color: #ffffff;
        border-color: #1e293b;
    }
</style>

<div class="collection-slider-content--gm" {{ block.shopify_attributes }} data-collection-item>
    <a href="{{ collection_url }}">
        <div class="collection-image-wrapper">
            {{ collection_image | image_url: width: 400, height: 400 | image_tag: alt: collection_name, crop: "center" }}
        </div>
        <span class="collection-name">
            {{ collection_name | replace: '_', ' ' | replace: '-', ' ' }}
        </span>
    </a>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const collectionItems = document.querySelectorAll('[data-collection-item]');
    const currentPath = window.location.pathname;
    
    // Function to scroll element into view within the slider
    function scrollItemIntoView(item) {
        const slider = document.querySelector('[data-slider]');
        if (!slider) return;
        
        const itemRect = item.getBoundingClientRect();
        const sliderRect = slider.getBoundingClientRect();
        
        // Calculate if item is out of view
        const isOutOfView = itemRect.left < sliderRect.left || itemRect.right > sliderRect.right;
        
        if (isOutOfView) {
            // Calculate the scroll position to center the item
            const itemCenter = item.offsetLeft + (item.offsetWidth / 2);
            const sliderCenter = slider.clientWidth / 2;
            const scrollTo = itemCenter - sliderCenter;
            
            slider.scrollTo({
                left: scrollTo,
                behavior: 'smooth'
            });
        }
    }
    
    collectionItems.forEach(item => {
        const link = item.querySelector('a');
        if (link) {
            const collectionPath = new URL(link.href).pathname;
            
            if (currentPath === collectionPath) {
                item.classList.add('active');
                // Scroll to active item on page load
                setTimeout(() => scrollItemIntoView(item), 100);
            }
        }
        
        item.addEventListener('click', function(e) {
            collectionItems.forEach(el => el.classList.remove('active'));
            this.classList.add('active');
            
            // Scroll clicked item into view
            scrollItemIntoView(this);
        });
    });
});
</script>