 
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="mega-menu-container">
  <nav class="page-width">
    <ul class="mega-menu">
      {% for block in section.blocks %}
        <li class="menu-item"  id="menu-{{ forloop.index0 }}">
          <a href="{{ block.settings.menuurl}}" class="menu-link">
            <div class="menu-icon-title">
               {% if block.settings.menuicon %}
              <img src="{{ block.settings.menuicon | img_url:'master' }}" alt="{{ block.settings.menuname }}">
              {% endif %}
              <span>{{ block.settings.menuname }}</span>
            </div>
          </a>




 {% if block.settings.megamenu1 == true %}
          
          <div class="submenu-wrapper">
            <div class="submenu-content">


              {% if block.settings.menuoneheading %}
              <div class="submenu-column {% if block.settings.megamenu12 == false %} custom-1 {% endif %}{% if block.settings.footwear_submenu_show %} submenu-column--stacked{% endif %}">
                <h3>{{ block.settings.menuoneheading }}</h3>
                <ul>
                  {% assign menu_items = linklists[block.settings.menu].links %}
                  {% for item in menu_items %}
                    <li><a href="{{ item.url }}"  {% if item.active  %} class="active" {% endif %}>{{ item.title }}</a></li>
                  {% endfor %}
                </ul>
                {% if block.settings.footwear_submenu_show %}
                  {% if block.settings.footwear_heading != blank or block.settings.footwear_menu != blank %}
                    <div id="mega-menu-footwear" class="submenu-footwear" data-mega-section="footwear">
                      <h3 class="submenu-footwear__title">
                        {% if block.settings.footwear_heading_url != blank %}
                          <a href="{{ block.settings.footwear_heading_url }}">{{ block.settings.footwear_heading | default: 'Footwear' | escape }}</a>
                        {% else %}
                          {{ block.settings.footwear_heading | default: 'Footwear' | escape }}
                        {% endif %}
                      </h3>
                      {% if block.settings.footwear_menu != blank %}
                        {% assign footwear_links = linklists[block.settings.footwear_menu].links %}
                        {% if footwear_links.size > 0 %}
                          <ul class="submenu-footwear__list">
                            {% for item in footwear_links %}
                              <li><a href="{{ item.url }}"{% if item.active %} class="active"{% endif %}>{{ item.title }}</a></li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      {% endif %}
                    </div>
                  {% endif %}
                {% endif %}
              </div>
              <script>
