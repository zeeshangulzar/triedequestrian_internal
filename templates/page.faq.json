    "accordion-section-1": {
      "type": "section-faq",
      "blocks": {
        "accordion_block_1_1": {
          "type": "text",
          "settings": {
            "title": "Is my payment data safe with you?",
            "content": "<p>All direct payment gateways adhere to the standards set by PCI-DSS as managed by the PCI Security Standards Council, which is a joint effort of brands like Visa, MasterCard, American Express, and Discover.</p>"
          }
        },
        "accordion_block_1_2": {
          "type": "text",
          "settings": {
            "title": "Do you accept online payments?",
            "content": "<p>Yes, we accept online payments. All payment processing and vital customer information is quick, easy, and secure.<br/></p><p>Learn more about our store's safe checkout experience (powered by Shopify) <a href=\"https://www.shopify.com/legal/terms#DataProtection\" target=\"_blank\" title=\"https://www.shopify.com/legal/terms#DataProtection\">here</a>.</p>"
          }
        },
        "accordion_block_1_3": {
          "type": "text",
          "settings": {
            "title": "Where can I learn more about the payment and processing on your store?",
            "content": "<p>For more insight, you may also want to read Shopify’s Terms of Service <a href=\"https://www.shopify.com/legal/terms\" target=\"_blank\" title=\"https://www.shopify.com/legal/terms\">here</a> or Privacy Statement <a href=\"https://www.shopify.com/legal/privacy\" target=\"_blank\" title=\"https://www.shopify.com/legal/privacy\">here</a>.</p>"
          }
        },
        "text_GKzzbV": {
          "type": "text",
          "settings": {
            "title": "Frequently asked question",
            "content": "<p>Share details about your shipping policies, item returns, or customer service.</p>"
          }
        },
        "accordion_block_1_4": {
          "type": "text",
          "settings": {
            "title": "What forms of payment do you accept?",
            "content": "<p>We accept payments from major credit card companies like Visa, Mastercard, and American Express. We also accept PayPal, Apple Pay, and ShopPay Installments.</p>"
          }
        }
      },
