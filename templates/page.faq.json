    "accordion-section-4": {
      "type": "section-faq",
      "blocks": {
        "accordion_block_4_0": {
          "type": "text",
          "settings": {
            "title": "Do you offer refunds?",
            "content": "<p>Yes, we always offer returns to give you full confidence in shopping pre-owned and discount!<br/><br/>You can view our full return policy <a href=\"/pages/return-policy-1\" title=\"Return Policy\">HERE</a>.</p>"
          }
        },
        "accordion_block_4_1": {
          "type": "text",
          "settings": {
            "title": "How long after I complete a purchase can I ask for a refund?",
            "content": "<p>A refund request can be submitted within 2 weeks after the purchase is delivered, confirmed by tracking.</p>"
          }
        },
        "accordion_block_4_3": {
          "type": "text",
          "settings": {
            "title": "Who pays the shipping costs in the case of a refund when the order doesn't have free shipping?",
            "content": "<p>When an order does not include free shipping, all shipping costs (including the return shipping) are handled by the customer.</p>"
          }
        },
        "accordion_block_4_4": {
          "type": "text",
          "settings": {
            "title": "Who pays the shipping costs in the case of a refund when the order has free shipping?",
            "content": "<p>When an order includes free shipping, only the cost of the return shipping is handled by the customer. *Excludes Saddles</p>"
          }
        },
        "text_cCtzw3": {
          "type": "text",
          "settings": {
            "title": "Expected Refund Times",
            "content": "<p><em>Returns can take up to a week to be processed.</em></p><ol><li><strong>Credit Card</strong> - Once processed, expect 3-7 business for the refund to be credited to your credit card account.</li><li><strong>Store Credit</strong> - Store Credit will be emailed same day the return is processed.</li><li><strong>Exchange</strong> - Any excess payment will be returned to the customer via store credit. If additional payment is needed on an exchange, an invoice will be emailed to the customer. The item(s) requested for exchange will be mailed the next business day after full payment is received.</li></ol>"
          }
        },
        "text_fTpeBn": {
          "type": "text",
          "settings": {
            "title": "Accepted Returns & Return Window",
            "content": "<p>The Tried Equestrian offers a 2 week return window, from the date of delivery, for all items excluding saddles. We offer a 5 day trial period for saddles from the date of delivery. Return requests must be emailed to TTE within return window. Return requests must be emailed to Mckenna@triedequestrian.com. The item(s) must arrive back in the same condition sent with the initial tags attached.</p>"
          }
        },
        "text_qqUtdB": {
          "type": "text",
          "settings": {
            "title": "Return Process for Saddles",
            "content": "<ol><li>Request a return within 5 days by emailing contact@triedequestrian.com</li><li>You will be emailed a prepaid return shipping label and return form. </li><li>$120 will be deducted from your return when your item is processed to cover the cost of initial shipping and the return shipment.  </li></ol>"
          }
        }
      },
