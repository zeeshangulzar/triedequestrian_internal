    "section_gallery_text_fQgcqp": {
      "type": "section-gallery-text",
      "blocks": {
        "text_Xctq9c": {
          "type": "text",
          "settings": {
            "title": "How You'll Get Paid",
            "title_size": 7,
            "text": "<p>At the beginning of the month, a check will be sent out with an invoice breakdown. We delay sending payments by one month to accommodate any returns. You are able to check the real-time status of your items in our <a href=\"https://tried-eq.herokuapp.com/auth/signin\" target=\"_blank\" title=\"https://tried-eq.herokuapp.com/auth/signin\">Consignor Portal</a>.</p><p><span style=\"text-decoration:underline\"><strong>Options to Receive Payment:</strong></span></p><ul><li>Mailed Check</li><li>Paypal</li><li>TriedEq Store Credit - Receive 10% more for your items!</li><li>Donate Sales to Charity!</li></ul>",
            "body_size": 5,
            "text_align": "text-left"
          }
        },
        "text_mMcjRx": {
          "type": "text",
          "disabled": true,
          "settings": {
            "title": "Additional Fees",
            "title_size": 7,
            "text": "<p></p><ul><li>$20/ shipment processing fee for shipped consignment kits</li><li>All boots not professionally cleaned are subject to a cleaning fee: $15 for paddock boots and $20 for tall boots. </li><li>Items needing dry cleaning or repairs are billed on a case by case basis.</li><li>Miscellaneous fees, never to exceed 10% of the sale price including excess shipping weights and free shipping to the customer</li></ul>",
            "body_size": 5,
            "text_align": "text-left"
          }
        }
      },
