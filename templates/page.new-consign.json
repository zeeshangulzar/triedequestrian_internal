        },
        "text_y8wTaf": {
          "type": "text",
          "settings": {
            "title": "Great",
            "text": "<h6>Subtle signs of wear or use. This may range from light wear from being washed, to moderate wear including light saddle or boot staining, some pilling, creasing to leather, etc.</h6>"
          }
        },
        "text_zdx6wX": {
          "type": "text",
          "settings": {
            "title": "Good",
            "text": "<h6>Moderate to heavier signs of wear. These are items that maybe have some thinning to the seat, heavier pilling, more noticeable saddle or boot staining, etc.</h6>"
