        "text_4qjhXX": {
          "type": "text",
          "settings": {
            "title": "Excellent",
            "text": "<h6>Essentially new without tags. The item should have no signs of use, wash, or wear, visible or otherwise. Few items are in excellent used condition.</h6>"
